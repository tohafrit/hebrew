			}
			else {
				sql = "Maagar_Pck.GET_SQL_HATAC_ZRF_NOT(";
			}
			sql += "''" + menukad.replace("'", "''''") + "'',";
			sql += "''" + zura.replace("'", "''''") + "'',";
			sql += "''" + document.getElementById("ctl00_ctl00_ContentPlaceHolder1_ContentPlaceHolder1_hKodim").value + "'',";
