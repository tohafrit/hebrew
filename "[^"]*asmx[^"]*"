			sql += document.getElementById("ctl00_ctl00_ContentPlaceHolder1_ContentPlaceHolder1_hLfiKodim").value;
			if (sug != 2) {
				sql += ",1)";
			}
			else {
				sql += ")";
			}
			return sql;
		}

